{
  "name": "agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "run-agent": "tsx --env-file=../server/.env src/cli/run-agent.ts"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.22",
    "@langchain/community": "^1.1.22",
    "@langchain/core": "^1.1.31",
    "@langchain/google-genai": "^2.1.24",
    "@langchain/langgraph": "^0.2.0",
    "@langchain/openai": "^1.2.12",
    "core": "workspace:*",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "globals": "^17.4.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^2.0.0"
  }
}
