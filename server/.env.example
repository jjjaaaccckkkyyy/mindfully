# Database
DATABASE_URL=postgresql://user:password@localhost:5432/mindful

# Session
SESSION_SECRET=your-random-32-character-secret-here

# OAuth - GitHub
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# OAuth - Google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email (production only)
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=noreply@yourdomain.com

# App
NODE_ENV=development
BASE_URL=http://localhost:3000
PORT=3000

# LLM Provider
# Priority order (comma-separated): opencode-zen,openai,anthropic,ollama,google
LLM_PROVIDERS=opencode-zen
LLM_MODEL=gpt-5.1-codex
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
OPENCODE_ZEN_API_KEY=your-opencode-zen-api-key
# Uncomment to add more providers to the fallback chain:
#OPENAI_API_KEY=your-openai-api-key
#ANTHROPIC_API_KEY=your-anthropic-api-key
#GOOGLE_API_KEY=your-google-api-key

# Web Search
BRAVE_API_KEY=your-brave-api-key

# Qdrant (vector store for RAG)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Context manager tuning (optional — these are the defaults)
EMBEDDING_MODEL=text-embedding-3-small
CONTEXT_WINDOW_SIZE=20
CONTEXT_SUMMARISE_THRESHOLD=40
CONTEXT_RAG_RESULTS=5
SUMMARY_MODEL=gpt-4o-mini

