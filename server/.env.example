# Database
DATABASE_URL=postgresql://user:password@localhost:5432/mindful

# Session
SESSION_SECRET=your-random-32-character-secret-here

# OAuth - GitHub
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# OAuth - Google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email (production only)
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=noreply@yourdomain.com

# App
NODE_ENV=development
BASE_URL=http://localhost:3000
PORT=3000

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Qdrant (vector store for RAG)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Context manager tuning (optional)
EMBEDDING_MODEL=text-embedding-3-small
CONTEXT_WINDOW_SIZE=20
CONTEXT_SUMMARISE_THRESHOLD=40
CONTEXT_RAG_RESULTS=5
SUMMARY_MODEL=glm-5

# LLM Provider
LLM_PROVIDERS=opencode-zen
LLM_MODEL=gpt-5.1-codex
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
# Connect timeout: ms to wait for the initial HTTP response headers
LLM_CONNECT_TIMEOUT_MS=15000
# Idle timeout: ms to wait for the next chunk once streaming has started
LLM_IDLE_TIMEOUT_MS=30000
OPENCODE_ZEN_API_KEY=your-opencode-zen-api-key
# Base URL for the opencode-zen proxy (defaults to https://opencode.ai/zen/v1)
OPENCODE_ZEN_BASE_URL=https://opencode.ai/zen/v1

# Anthropic (optional — used when LLM_PROVIDERS includes 'anthropic')
ANTHROPIC_API_KEY=

# Summary LLM (used for session summarisation and title generation)
# Uses the OpenCode Zen proxy by default (same key as OPENCODE_ZEN_API_KEY).
# Set SUMMARY_BASE_URL to redirect summarisation to a different endpoint.
SUMMARY_BASE_URL=https://opencode.ai/zen/v1

